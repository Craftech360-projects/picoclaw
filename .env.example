# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# MODELSCOPE_API_KEY=xxx
# CLAUDE_CODE_OAUTH=xxx
# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# Feishu (飞书)
# PICOCLAW_CHANNELS_FEISHU_APP_ID=cli_xxx
# PICOCLAW_CHANNELS_FEISHU_APP_SECRET=xxx
# PICOCLAW_CHANNELS_FEISHU_RANDOM_REACTION_EMOJI=Typing,OneSecond

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Shanghai

# LiveKit manager-backed session persistence
# Enable this when LiveKit workers should persist turns through Manager API
# instead of relying only on the local workspace.
# PICOCLAW_LIVEKIT_MANAGER_SESSION_STORE_ENABLED=true
# PICOCLAW_LIVEKIT_MANAGER_API_URL=http://localhost:8002/toy
# PICOCLAW_LIVEKIT_MANAGER_API_SERVICE_KEY=change-me
# PICOCLAW_LIVEKIT_MANAGER_RECENT_LIMIT=50
